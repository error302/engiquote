generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String    @id @default(uuid())
  name      String
  email     String?
  phone     String?
  company   String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  invoices  Invoice[]
}

model Project {
  id             String       @id @default(uuid())
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  name           String
  type           ProjectType
  status         ProjectStatus @default(PENDING)
  description    String?
  location       String?      // County for rate lookup
  discipline     String       @default("BUILDING") // BUILDING|CIVIL|MECHANICAL|ARCHITECTURE
  startDate      DateTime?
  endDate        DateTime?
  cashFlowCurve  String       @default("S_CURVE")
  cashFlow       Json?
  dailyBurnKsh   Decimal?     @db.Decimal(12, 2)
  peakDailyBurnKsh Decimal?   @db.Decimal(12, 2)
  inputSource    String       @default("MANUAL") // MANUAL|DWG|IFC|PDF
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  quotes         Quote[]
  tasks          Task[]
  quoteShares    QuoteShare[]
  variationOrders VariationOrder[]
  actualExpenses  ActualExpense[]
}

model Quote {
  id                   String      @id @default(uuid())
  projectId            String
  project              Project     @relation(fields: [projectId], references: [id])
  quoteNumber          String      @unique
  status               QuoteStatus @default(DRAFT)
  subtotal             Decimal     @db.Decimal(12, 2)
  profitMarginPercent  Decimal     @db.Decimal(5, 2) @default(10)
  profitAmount         Decimal     @db.Decimal(12, 2)
  taxPercent           Decimal     @db.Decimal(5, 2) @default(16)
  taxAmount            Decimal     @db.Decimal(12, 2)
  total                Decimal     @db.Decimal(12, 2)
  currency             String      @default("KES")
  validUntil           DateTime?
  notes                String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  items                QuoteItem[]
  invoices             Invoice[]
  approval             QuoteApproval?
  followUps            FollowUp[]
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  category    String
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unit        String
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
}

model QuoteTemplate {
  id          String              @id @default(uuid())
  name        String
  description String?
  projectType String?
  items       QuoteTemplateItem[]
  recurring   RecurringQuote[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model QuoteTemplateItem {
  id            String         @id @default(uuid())
  templateId    String
  template     QuoteTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category      String
  description   String
  quantity     Decimal        @db.Decimal(10, 2) @default(1)
  unit         String
  unitPrice    Decimal        @db.Decimal(12, 2)
}

model Material {
  id          String   @id @default(uuid())
  name        String
  category    String
  unit        String
  unitPrice   Decimal  @db.Decimal(12, 2)
  description String?
  county      String   @default("NAIROBI") // NAIROBI|MOMBASA|KISUMU|NAKURU|ELDORET
}

model LaborRate {
  id          String   @id @default(uuid())
  role        String
  hourlyRate  Decimal  @db.Decimal(12, 2)
  description String?
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  role          UserRole      @default(SALES)
  active        Boolean       @default(true)
  companyUsers  CompanyUser[]
  auditLogs     AuditLog[]
  approvals     ApprovalStep[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum UserRole {
  ADMIN
  SALES
  VIEWER
}

enum ProjectType {
  CIVIL
  ELECTRICAL
  MECHANICAL
  ARCHITECTURE
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model Invoice {
  id            String        @id @default(uuid())
  quoteId       String?
  quote         Quote?        @relation(fields: [quoteId], references: [id])
  invoiceNumber String        @unique
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @db.Decimal(12, 2) @default(0)
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime?
  issueDate     DateTime      @default(now())
  notes         String?
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Payment {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @default(now())
  method      String?
  reference   String?
  status      String   @default("PENDING")
  notes       String?
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model Task {
  id          String      @id @default(uuid())
  projectId    String
  project     Project     @relation(fields: [projectId], references: [id])
  title       String
  description String?
  status      TaskStatus  @default(PENDING)
  priority    String      @default("MEDIUM")
  dueDate     DateTime?
  assigneeId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Attachment {
  id          String   @id @default(uuid())
  filename    String
  s3Key       String   @unique
  s3Url       String
  mimeType    String
  size        Int
  entityType  String
  entityId    String
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

// Multi-company support
model Company {
  id            String   @id @default(uuid())
  name          String
  logo          String?
  primaryColor  String   @default("#1E40AF")
  secondaryColor String  @default("#3B82F6")
  email         String?
  phone         String?
  address       String?
  website       String?
  currency      String   @default("KES")
  taxId         String?
  settings      CompanySettings?
  users         CompanyUser[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanySettings {
  id              String  @id @default(uuid())
  companyId       String  @unique
  company         Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultTaxRate  Decimal @db.Decimal(5, 2) @default(16)
  defaultProfit   Decimal @db.Decimal(5, 2) @default(10)
  quoteValidity   Int     @default(30)
  invoiceDueDays  Int     @default(30)
  slackWebhook    String?
  teamsWebhook    String?
  googleDriveFolder String?
  approvalThreshold Decimal @db.Decimal(12, 2) @default(100000)
}

model CompanyUser {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      CompanyRole @default(MEMBER)
  createdAt DateTime @default(now())
}

enum CompanyRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

// Audit logs
model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

// Recurring quotes
model RecurringQuote {
  id              String           @id @default(uuid())
  name            String
  clientId        String
  projectId       String
  templateId      String?
  frequency       RecurringFrequency
  nextRunDate     DateTime
  lastRunDate     DateTime?
  items           QuoteTemplateItem[]
  profitMargin    Decimal          @db.Decimal(5, 2) @default(10)
  taxPercent      Decimal          @db.Decimal(5, 2) @default(16)
  autoSend        Boolean          @default(false)
  active          Boolean          @default(true)
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// Approval workflows
model ApprovalWorkflow {
  id          String       @id @default(uuid())
  name        String
  threshold   Decimal      @db.Decimal(12, 2)
  approvers   ApprovalStep[]
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ApprovalStep {
  id              String          @id @default(uuid())
  workflowId      String
  workflow        ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepNumber      Int
  approverId      String
  approver        User            @relation("ApprovalApprover", fields: [approverId], references: [id])
  status          ApprovalStatus  @default(PENDING)
  comments        String?
  createdAt       DateTime        @default(now())
}

model QuoteApproval {
  id          String         @id @default(uuid())
  quoteId     String         @unique
  quote       Quote          @relation(fields: [quoteId], references: [id])
  workflowId  String
  workflow    ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  currentStep Int            @default(1)
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Marketplace
model MarketplaceTemplate {
  id          String    @id @default(uuid())
  name        String
  description String?
  category    String
  projectType ProjectType?
  price       Decimal   @db.Decimal(12, 2) @default(0)
  rating      Decimal   @db.Decimal(3, 2) @default(0)
  downloads   Int       @default(0)
  items       MarketplaceItem[]
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model MarketplaceItem {
  id          String            @id @default(uuid())
  templateId  String
  template    MarketplaceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category    String
  description String
  quantity    Decimal           @db.Decimal(10, 2) @default(1)
  unit        String
  unitPrice   Decimal           @db.Decimal(12, 2)
}

model MarketplaceRate {
  id          String   @id @default(uuid())
  category    String
  name        String
  unit        String
  avgPrice    Decimal  @db.Decimal(12, 2)
  minPrice    Decimal  @db.Decimal(12, 2)
  maxPrice    Decimal  @db.Decimal(12, 2)
  region      String   @default("Kenya")
  year        Int
  source      String?
  updatedAt   DateTime @default(now())
}

// Integration configs
model Integration {
  id          String            @id @default(uuid())
  companyId   String
  provider    IntegrationProvider
  accessToken String?
  refreshToken String?
  settings    String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum IntegrationProvider {
  QUICKBOOKS
  XERO
  SLACK
  TEAMS
  GOOGLE_DRIVE
}

// Follow-up tracking
model FollowUp {
  id        String   @id @default(uuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id])
  sentAt    DateTime @default(now())
  type      String
  email     String
  subject   String
  status    String   @default("SENT")
}

// Client Quote Portal
model QuoteShare {
  id          String       @id @default(uuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id])
  token       String       @unique @default(uuid())
  clientName  String?
  clientEmail String?
  status      QuoteStatus  @default(PENDING)
  comments    String?
  viewedAt    DateTime?
  approvedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
}

// Statutory Fees
model StatutoryFee {
  id          String  @id @default(uuid())
  name        String
  basis       String  // PERCENTAGE_OF_COST | FIXED | RANGE
  rate        Decimal? // if percentage
  fixedKsh    Decimal? // if fixed
  minKsh      Decimal?
  maxKsh      Decimal?
  county      String  @default('ALL')
  projectType String  @default('ALL')
  isActive    Boolean @default(true)
  notes       String?
}

// Variation Orders
model VariationOrder {
  id            String     @id @default(uuid())
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id])
  voNumber      Int
  description   String
  items         Json       // array of added/removed/changed items
  netChangeKsh  Decimal    @db.Decimal(12, 2)
  status        VOStatus   @default(DRAFT)
  pdfUrl        String?
  createdAt     DateTime   @default(now())
}

enum VOStatus {
  DRAFT
  ISSUED
  CLIENT_APPROVED
  CLIENT_REJECTED
}

// Actuals tracking
model ActualExpense {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  boqItemId   String?
  description String
  amountKsh   Decimal  @db.Decimal(12, 2)
  category    String
  receiptUrl  String?
  spentAt     DateTime @default(now())
}
